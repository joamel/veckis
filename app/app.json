{
  "expo": {
    "name": "Veckis",
    "slug": "veckis",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "veckis",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.veckis.app"
    },
    "android": {
      "package": "com.veckis.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
