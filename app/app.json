{
  "expo": {
    "name": "Veckis",
    "slug": "veckis",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "veckis",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.veckis.app"
    },
    "android": {
      "package": "com.veckis.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "37425b58-c8af-45be-aac8-c26bbdfaa3d1"
      }
    },
    "owner": "joamel"
  }
}
