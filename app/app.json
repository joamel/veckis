{
  "expo": {
    "name": "Veckis",
    "slug": "veckis",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/37425b58-c8af-45be-aac8-c26bbdfaa3d1"
    },
    "orientation": "default",
    "scheme": "veckis",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.veckis.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.veckis.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF7F0"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#292524",
      "barStyle": "light-content",
      "translucent": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      "./plugins/withDisableAutofill",
      [
        "expo-image-picker",
        {
          "photosPermission": "Veckis behöver tillgång till dina bilder för att välja receptbild.",
          "cameraPermission": "Veckis behöver kameran för att ta en receptbild."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "37425b58-c8af-45be-aac8-c26bbdfaa3d1"
      }
    },
    "owner": "joamel"
  }
}
