# Test-databas för integrationstester. Skapas separat från dev-DB:n så att
# tester inte rör utvecklarens lokala data.
#
# Setup (kör en gång lokalt):
#   1. Skapa DB:n:
#        node -e "const {PrismaClient} = require('@prisma/client'); \
#                 const p = new PrismaClient({datasources:{db:{url:'postgresql://veckis:veckis@localhost:5432/postgres'}}}); \
#                 p.\$executeRawUnsafe('CREATE DATABASE veckis_test WITH OWNER veckis').then(()=>p.\$disconnect());"
#   2. Kopiera den här filen till .env.test
#   3. Applicera migrations:
#        DATABASE_URL="postgresql://veckis:veckis@localhost:5432/veckis_test" npx prisma migrate deploy
#   4. Kör testerna:
#        npm test
#
# Setup.ts har en säkerhetsspärr som kräver att DATABASE_URL innehåller
# "veckis_test" — så testerna kan inte oavsiktligt truncate:a dev-DB:n.

DATABASE_URL="postgresql://veckis:veckis@localhost:5432/veckis_test"
NODE_ENV="test"
CLERK_SECRET_KEY="sk_test_mock_for_tests"
PORT=3001
