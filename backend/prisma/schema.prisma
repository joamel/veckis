generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Household {
  id        String   @id @default(cuid())
  name      String
  emoji     String?  @default("🏠")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       HouseholdMember[]
  inviteCodes   InviteCode[]
  shoppingLists ShoppingList[]
  stores        Store[]
  chores        Chore[]
  scheduleItems ScheduleEntry[]
  recipes       Recipe[]
  weekMenuItems WeekMenuItem[]
  stapleItems   StapleItem[]
  menuTemplates MenuTemplate[]
}

model HouseholdMember {
  id          String   @id @default(cuid())
  householdId String
  clerkUserId String?
  displayName String
  role        MemberRole @default(member)
  joinedAt    DateTime   @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, clerkUserId])
  @@index([clerkUserId])
}

model InviteCode {
  id          String   @id @default(cuid())
  code        String   @unique
  householdId String
  createdBy   String
  expiresAt   DateTime
  usedAt      DateTime?
  usedBy      String?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([code])
}

model Store {
  id                String        @id @default(cuid())
  householdId       String
  name              String
  categoryOrder     StoreCategory[]
  customCategories  String[]      @default([])
  // Subs som hushållet brutit ut som egna sektioner under sin parent.
  // Övriga items grupperas under parent som idag. Strängar refererar till
  // SubCategory-värden i shared/lib/taxonomy.ts.
  expandedSubs      String[]      @default([])
  createdAt         DateTime      @default(now())

  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  shoppingLists ShoppingList[]
}

model ShoppingList {
  id          String    @id @default(cuid())
  householdId String
  name        String
  emoji       String?
  storeId     String?
  isShared    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  // "Jag handlar"-presence: vem som aktivt handlar listan just nu. Sätts av
  // användaren själv via PATCH /shopping-lists/:id/shopper och rensas
  // manuellt eller automatiskt vid clear/complete. Andra hushållsmedlemmar
  // ser en markör så ingen råkar göra dubbla turer till affären.
  activeShopperMemberId String?
  activeShopperSince    DateTime?

  household Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  store     Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  items     ShoppingItem[]

  @@index([householdId])
}

model ShoppingItem {
  id           String        @id @default(cuid())
  listId       String
  name         String
  quantity     Float         @default(1)
  unit         String?
  category     StoreCategory @default(other)
  // 2-nivå-taxonomi: subCategory är källa till sanning för aggregering/AI/sök;
  // category är parent (sub:ens defaultParent vid skapande, kan override:as
  // per item). Skickas som string för att frikoppla från enum-deploys —
  // shared/lib/taxonomy.ts håller listan över giltiga värden.
  subCategory  String?
  customCategory String?  // DEPREKERAD — migreras till subCategory; UI dolt
  isChecked    Boolean       @default(false)
  checkedBy    String?
  addedBy      String
  note         String?
  recipeId     String?
  menuItemId   String?
  mergedIntoId String?
  createdAt    DateTime      @default(now())

  list         ShoppingList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  recipe       Recipe?        @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  mergedInto   ShoppingItem?  @relation("MergeChildren", fields: [mergedIntoId], references: [id], onDelete: Cascade)
  mergeSources ShoppingItem[] @relation("MergeChildren")

  @@index([listId])
  @@index([menuItemId])
  @@index([mergedIntoId])
}

model Chore {
  id          String         @id @default(cuid())
  householdId String
  title       String
  emoji       String?
  description String?
  frequency   ChoreFrequency @default(weekly)
  assignedTo  String?
  // Multi-assign: lista över medlems-id (lokala profiler eller Clerk-medlemmar).
  // assignedTo behålls i sync via syncAssignedTo (många[0]) för gamla klienter.
  assignedToMany       String[]       @default([])
  // När true turas medlemmarna i assignedToMany om per tillfälle
  // (turn = list[occurrenceIndex % list.length], deterministisk).
  rotation             Boolean        @default(false)
  days        WeekDay[]
  isShared    Boolean        @default(true)
  startDate   String?
  endDate     String?
  recurrenceType        RecurrenceType @default(none)
  recurrenceWeeks       Int            @default(1)
  monthlyType           String         @default("day_of_month")
  recurrenceWeekOfMonth Int?
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  completions ChoreCompletion[]

  @@index([householdId])
}

model ChoreCompletion {
  id          String   @id @default(cuid())
  choreId     String
  completedBy String   // audit: clerkUserId of the user who pressed Klar
  performedByMemberId String? // semantic: HouseholdMember who actually did it (may be a local profile); null = same as completedBy
  completedAt DateTime @default(now())
  note        String?
  day         WeekDay?
  date        String?  // YYYY-MM-DD — specific date this completion covers

  chore Chore @relation(fields: [choreId], references: [id], onDelete: Cascade)

  @@index([choreId])
}

model ScheduleEntry {
  id                   String             @id @default(cuid())
  householdId          String
  title                String
  emoji                String?
  description          String?
  day                  WeekDay
  startTime            String?
  endTime              String?
  assignedTo           String?
  assignedToMany       String[]           @default([])
  isShared             Boolean            @default(true)
  remind               Boolean            @default(true)
  remindMinutes        Int[]              @default([])
  recurrenceType       RecurrenceType     @default(none)
  recurrenceDays       WeekDay[]
  recurrenceWeeks      Int                @default(1)
  monthlyType          String             @default("day_of_month")
  recurrenceWeekOfMonth Int?
  exceptions           String[]           @default([])
  startDate            String?
  endDate              String?
  createdBy            String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, day])
}

model Recipe {
  id          String   @id @default(cuid())
  householdId String
  title       String
  description String?
  instructions String?
  sourceUrl   String?
  imageUrl    String?
  imagePublicId String?  // Cloudinary public_id for the uploaded image, so we can delete it on change/recipe-delete
  servings    Int      @default(4)
  timesUsed   Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household     Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ingredients   RecipeIngredient[]
  weekMenuItems WeekMenuItem[]
  shoppingItems ShoppingItem[]
  menuTemplateItems MenuTemplateItem[]

  @@index([householdId])
}

model RecipeIngredient {
  id       String        @id @default(cuid())
  recipeId String
  name     String
  quantity Float?
  unit     String?
  category StoreCategory @default(other)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model WeekMenuItem {
  id          String   @id @default(cuid())
  householdId String
  recipeId    String
  day         WeekDay?
  weekYear    Int
  weekNumber  Int
  note        String?
  servings     Int?     // per-placement portion scaling; null = use recipe default
  transferred  Boolean  @default(false) // set when ingredients have been sent to a shopping list
  createdBy   String
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipe    Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([householdId, weekYear, weekNumber])
}

model MenuTemplate {
  id          String   @id @default(cuid())
  householdId String
  name        String
  createdBy   String
  createdAt   DateTime @default(now())

  household Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     MenuTemplateItem[]

  @@index([householdId])
}

model MenuTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  recipeId   String
  day        WeekDay?

  template MenuTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  recipe   Recipe       @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model StapleItem {
  id              String        @id @default(cuid())
  householdId     String
  name            String
  category        StoreCategory @default(other)
  unit            String?
  defaultQuantity Float?
  usageCount      Int           @default(0) // times added to a list — drives "dina vanligaste"

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, name])
  @@index([householdId])
}

model IngredientAlias {
  raw       String        @id
  canonical String
  category  StoreCategory @default(other)
  seenCount Int           @default(1)

  @@index([canonical])
}

// One row per device/token. A user (clerkUserId) may have several.
model PushToken {
  id          String   @id @default(cuid())
  clerkUserId String
  token       String   @unique
  platform    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clerkUserId])
}

// Per-user push preferences (global across households). Defaults all on.
model NotificationPreference {
  clerkUserId      String   @id
  activityReminder Boolean  @default(true)
  choreOverdue     Boolean  @default(true)
  listCleared      Boolean  @default(true)
  newMember        Boolean  @default(true)
  shopperClaimed   Boolean  @default(true)
  choreCompleted   Boolean  @default(true)
  reminderMinutes  Int      @default(30) // minutes before an activity start to remind
  updatedAt        DateTime @updatedAt
}

// Dedupe ledger for time-based notifications so a reminder fires once per
// occurrence. `dedupeKey` encodes type + entity + occurrence date/time.
model NotificationLog {
  id        String   @id @default(cuid())
  dedupeKey String   @unique
  sentAt    DateTime @default(now())

  @@index([sentAt])
}

// Auditspår för känsliga handlingar — vem raderade hushållet, vem
// tog bort en medlem, vem ändrade en roll. Sökbart per hushåll/aktör
// så vi kan svara på "vem gjorde vad" om en användare ifrågasätter.
//
// Ingen FK till Household/HouseholdMember för att raderingar fortsatt
// ska kunna logga — vi behöver loggraden EFTER att target raderats.
model AuditLog {
  id          String   @id @default(cuid())
  householdId String?  // null för system-events utanför ett hushåll
  actorClerkUserId String  // vem som utförde
  actorName   String?  // snapshot av display-namn vid handlingen
  action      String   // ex: "household.delete", "member.remove", "member.role_change"
  targetType  String?  // "household" | "member" | osv
  targetId    String?  // id på det som ändrades
  targetName  String?  // snapshot (för bortagna entiteter)
  metadata    Json?    // valfri extra info: gammalt/nytt värde, anledning
  createdAt   DateTime @default(now())

  @@index([householdId, createdAt])
  @@index([actorClerkUserId, createdAt])
}

enum MemberRole {
  admin
  member
}

enum StoreCategory {
  fruit_veg
  meat_fish
  deli_charcuterie
  cheese
  dairy_eggs
  bread_bakery
  frozen
  canned_dry
  snacks_sweets
  beverages
  special_diet
  cleaning
  personal_care
  other
}

enum ChoreFrequency {
  once
  daily
  weekly
  biweekly
  monthly
}

enum WeekDay {
  mon
  tue
  wed
  thu
  fri
  sat
  sun
}

enum RecurrenceType {
  none
  daily
  weekly
  custom_days
  monthly
  yearly
}
